/* General Styling */
body {
    font-family: Arial, sans-serif;
    background: linear-gradient(to right, #3498db, #6dd5fa);
    margin: 0;
    padding: 0;
}

/* Main Container */
.container {
    width: 85%;
    margin: 30px auto;
    padding: 20px;
}

/* Headings */
h1 {
    text-align: center;
    color: white;
    font-size: 36px;
    margin-bottom: 5px;
}

h2 {
    text-align: center;
    color: #f0f0f0;
    margin-bottom: 30px;
}

/* Event Info & Form Sections */
.event-info,
.form-section {
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    margin-bottom: 30px;
}

/* Event Text */
.event-info p {
    line-height: 1.6;
}

.event-info ul {
    padding-left: 20px;
}

/* Form Styling */
form label {
    font-weight: bold;
    display: block;
    margin-top: 10px;
}

form input,
form select,
form textarea {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    margin-bottom: 15px;
    border-radius: 6px;
    border: 1px solid #ccc;
    transition: 0.3s;
}

/* Input Focus Effect */
form input:focus,
form select:focus,
form textarea:focus {
    border-color: #3498db;
    outline: none;
    box-shadow: 0 0 5px #3498db;
}

/* Submit Button */
form input[type="submit"] {
    background-color: #3498db;
    color: white;
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: bold;
}

form input[type="submit"]:hover {
    background-color: #2c80b4;
    transform: scale(1.03);
}
